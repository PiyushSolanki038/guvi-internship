<?php
/**
 * .env.php.example
 * Copy this file to .env.php and fill in your local values.
 * .env.php is in .gitignore — never commit real credentials.
 */
putenv('MYSQL_HOST=localhost');
putenv('MYSQL_PORT=3306');
putenv('MYSQL_USER=root');
putenv('MYSQL_PASS=');
putenv('MYSQL_DB=guvi_auth');

putenv('MONGO_URI=mongodb://localhost:27017');
putenv('MONGO_DB=guvi_profiles');
putenv('MONGO_COL=profiles');

putenv('REDIS_HOST=127.0.0.1');
putenv('REDIS_PORT=6379');
putenv('REDIS_PASS=');
